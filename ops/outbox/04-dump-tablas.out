=== eventos ===
schema:
CREATE TABLE eventos (
  id             INTEGER PRIMARY KEY AUTOINCREMENT,
  timestamp      DATETIME DEFAULT CURRENT_TIMESTAMP,
  canal          TEXT NOT NULL CHECK(canal IN ('whatsapp','gmail','calendar','sistema')),
  direccion      TEXT NOT NULL CHECK(direccion IN ('entrante','saliente','interno')),
  de             TEXT,
  nombre         TEXT,
  asunto         TEXT,
  cuerpo         TEXT,
  tipo_original  TEXT,
  metadata_json  TEXT
);
CREATE INDEX idx_eventos_ts       ON eventos(timestamp DESC);
CREATE INDEX idx_eventos_canal_ts ON eventos(canal, timestamp DESC);
CREATE INDEX idx_eventos_de       ON eventos(de);
