=== pendientes ===
schema:
CREATE TABLE pendientes (
  id                  INTEGER PRIMARY KEY AUTOINCREMENT,
  creado              DATETIME DEFAULT CURRENT_TIMESTAMP,
  desc                TEXT NOT NULL,
  estado              TEXT NOT NULL DEFAULT 'abierto' CHECK(estado IN ('abierto','cerrado','cancelado')),
  cerrado             DATETIME,
  ultimo_recordatorio DATETIME,
  remitente           TEXT,
  canal_origen        TEXT,
  destino_wa          TEXT,
  destino_email       TEXT,
  email_message_id    TEXT,
  meta_json           TEXT
);
CREATE INDEX idx_pendientes_estado ON pendientes(estado, creado);
CREATE INDEX idx_pendientes_remit  ON pendientes(remitente, estado);
