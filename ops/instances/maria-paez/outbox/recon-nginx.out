# Landing en / (estática, /var/www/veritas-trace)
# POC en /POC/ (proxy_pass al uvicorn 127.0.0.1:8000, FastAPI con --root-path /POC)
server {
    server_name veritas-trace.com www.veritas-trace.com;

    root /var/www/veritas-trace;
    index index.html;

    access_log /var/log/nginx/veritas-trace.access.log;
    error_log  /var/log/nginx/veritas-trace.error.log;

    gzip on;
    gzip_types text/css application/javascript image/svg+xml application/json;
    gzip_min_length 256;

    # Redirect /POC → /POC/ (sin slash final)
    location = /POC {
        return 301 /POC/;
    }

    # POC: proxy al uvicorn — el trailing slash en proxy_pass strippa /POC del path
    location /POC/ {
        proxy_pass http://127.0.0.1:8000/;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Prefix /POC;
        proxy_redirect off;
        proxy_buffering off;
    }

    # Assets versionados de la landing (cache largo, hash en filename)
    location /assets/ {
        expires 1y;
        add_header Cache-Control "public, immutable";
        try_files $uri =404;
    }

    # SPA: cualquier ruta no encontrada → index.html de la landing
    location / {
        try_files $uri $uri/ /index.html;
    }

    listen [::]:443 ssl ipv6only=on; # managed by Certbot
    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/www.veritas-trace.com/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/www.veritas-trace.com/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot

}

server {
    if ($host = www.veritas-trace.com) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    listen 80 default_server;
    listen [::]:80 default_server;
    server_name veritas-trace.com www.veritas-trace.com;
    return 404; # managed by Certbot


}
