═══ 1. Confirmar el bug — el FK de portal_otp apunta a clientes_old ═══
CREATE TABLE portal_otp (
  id                INTEGER PRIMARY KEY AUTOINCREMENT,
  cliente_id        INTEGER NOT NULL REFERENCES "clientes_old"(id) ON DELETE CASCADE,
  canal             TEXT NOT NULL CHECK(canal IN ('email','wa')),
  code              TEXT NOT NULL,                -- 6 dígitos
  intentos          INTEGER NOT NULL DEFAULT 0,
  usado             INTEGER NOT NULL DEFAULT 0,
  creado            DATETIME DEFAULT CURRENT_TIMESTAMP,
  expira_en         DATETIME NOT NULL              -- 10min
);
CREATE INDEX idx_portal_otp_cliente ON portal_otp(cliente_id, expira_en);
CREATE TABLE portal_sessions (
  id                INTEGER PRIMARY KEY AUTOINCREMENT,
  cliente_id        INTEGER NOT NULL REFERENCES "clientes_old"(id) ON DELETE CASCADE,
  token             TEXT NOT NULL UNIQUE,         -- cookie value, criptográficamente random
  creado            DATETIME DEFAULT CURRENT_TIMESTAMP,
  expira_en         DATETIME NOT NULL,            -- 30min de validez
  ip_origen         TEXT,
  user_agent        TEXT
);
CREATE INDEX idx_portal_expira ON portal_sessions(expira_en);

