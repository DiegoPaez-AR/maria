═══ NGINX vhost de intensa.io ═══
--- /etc/nginx/sites-enabled/intensa.io.conf ---
# /etc/nginx/sites-available/intensa.io.conf
# Sitio estático intensa.io. Servido desde /var/www/intensa.io/.
# SSL: agregado por certbot --nginx (no editar las líneas managed by Certbot).

server {
    server_name intensa.io www.intensa.io;

    root /var/www/intensa.io;
    index index.html;

    access_log /var/log/nginx/intensa.io.access.log;
    error_log  /var/log/nginx/intensa.io.error.log;

    gzip on;
    gzip_types text/css application/javascript image/svg+xml application/json text/html;
    gzip_min_length 256;

    # Cache largo para assets versionables (si aparecen)
    location ~* \.(css|js|svg|png|jpg|jpeg|webp|woff2?)$ {
        expires 7d;
        add_header Cache-Control "public";
        try_files $uri =404;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }

    listen [::]:443 ssl; # managed by Certbot
    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/intensa.io/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/intensa.io/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot


}


server {
    if ($host = www.intensa.io) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    if ($host = intensa.io) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    listen 80;
    listen [::]:80;
    server_name intensa.io www.intensa.io;
    return 404; # managed by Certbot




}
